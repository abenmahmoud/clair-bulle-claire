# Provider IA actif : claude | openai | kimi
AI_PROVIDER=claude

# Cles API serveur. Ne jamais exposer cote client.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# Modeles optionnels. Les valeurs par defaut sont configurees dans src/lib/ai/factory.ts.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini
MOONSHOT_MODEL=kimi-k2.6

# === Sprint 3 : Supabase Auth + Storage ===
# Projet Supabase EU (Frankfurt) — RGPD compliant
# Récupérer depuis : Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
