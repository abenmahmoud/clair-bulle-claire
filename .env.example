# Provider IA actif : claude | openai | kimi
AI_PROVIDER=claude

# Cles API serveur. Ne jamais exposer cote client.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# Modeles optionnels. Les valeurs par defaut sont configurees dans src/lib/ai/factory.ts.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini
MOONSHOT_MODEL=kimi-k2.6
